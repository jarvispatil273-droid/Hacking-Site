# ============================================================================
# AEGIS — environment configuration
# Copy to `.env.local` and fill in what you have. Everything is OPTIONAL:
# with nothing set, the app runs on the local file-backed store with seed data
# and deterministic (non-AI) summaries.
# ============================================================================

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase (leave blank to use the local JSON store) ---
# When BOTH url + anon key are set, the app switches to the Supabase backend.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role is server-only; used by the ingestion pipeline to write articles.
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI (leave blank to use the deterministic extractive fallback) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- NVD (CVE Explorer) ---
# Optional API key raises NVD rate limits from 5 to 50 requests / 30s.
NVD_API_KEY=

# --- Automation ---
# Shared secret the Vercel Cron job must send as `Authorization: Bearer <secret>`
# (or `?secret=`) to trigger /api/cron/ingest. Generate a random value.
CRON_SECRET=change-me-to-a-long-random-string

# --- Local guest session signing (fallback auth when Supabase is absent) ---
GUEST_SESSION_SECRET=change-me-too
